{
	email {$ACME_EMAIL}
}

{$PULSE_HOST} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy stone:8080
	}

	handle /ws {
		reverse_proxy stone:8080
	}

	handle /uploads/* {
		header Cache-Control "public, max-age=86400, immutable"
		reverse_proxy stone:8080
	}

	handle {
		root * /srv/ember
		try_files {path} /index.html
		file_server
	}
}
