ENV=production
PORT=8080
STONE_IMAGE=ghcr.io/miguelcsx/pulse/stone:latest
WEB_IMAGE=ghcr.io/miguelcsx/pulse/web:latest

POSTGRES_PASSWORD=replace-with-generated-password
DATABASE_URL=postgres://pulse:replace-with-generated-password@postgres:5432/pulse?sslmode=disable
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-at-least-32-random-chars

DEMO_AUTH_ENABLED=true
CORS_ORIGINS=http://replace-with-lightsail-public-ip
WS_ORIGINS=http://replace-with-lightsail-public-ip
AUTH_COOKIE_SECURE=false

STORAGE_PATH=/app/uploads
STORAGE_BASE_URL=/uploads
UPLOAD_PUBLIC_PATH=/uploads
STORAGE_MAX_SIZE_MB=25

TRUSTED_PROXIES=172.16.0.0/12,127.0.0.1,::1
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60
RATE_LIMIT_FAIL_OPEN=true

METRICS_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=
