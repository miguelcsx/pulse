FROM node:24-bookworm AS build

WORKDIR /src
COPY drift/ts ./drift/ts
COPY ember/package.json ember/package-lock.json ./ember/
WORKDIR /src/ember
RUN npm ci

WORKDIR /src
COPY ember ./ember
WORKDIR /src/ember
ARG VITE_DEMO_MODE=true
ENV VITE_DEMO_MODE=${VITE_DEMO_MODE}
RUN npm run build

FROM caddy:2-alpine
COPY deploy/lightsail/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /src/ember/dist /srv/ember
